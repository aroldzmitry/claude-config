{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "plan-validator-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "plan-validator" },
    "data": {
      "type": "object",
      "required": ["result"],
      "properties": {
        "result": { "type": "string", "enum": ["clean", "fixed", "partial"] },
        "issues_fixed": { "type": "integer", "minimum": 0 },
        "issues_remaining": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
