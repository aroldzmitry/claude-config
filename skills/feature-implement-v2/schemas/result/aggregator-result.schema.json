{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aggregator-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "aggregator" },
    "data": {
      "type": "object",
      "required": ["result", "verified_issue_count", "false_positive_count"],
      "properties": {
        "result": { "type": "string", "enum": ["clean", "issues_found"] },
        "verified_issue_count": { "type": "integer", "minimum": 0 },
        "false_positive_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
