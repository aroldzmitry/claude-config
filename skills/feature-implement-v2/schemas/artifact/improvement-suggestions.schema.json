{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "improvement-suggestions.schema.json",
  "type": "object",
  "required": ["version", "run_id", "summary"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["count"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "regressions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_file", "action", "description"],
        "properties": {
          "target_file": { "type": "string" },
          "action": { "type": "string", "enum": ["replace", "insert", "delete"] },
          "old_text": { "type": "string" },
          "new_text": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "target", "issue", "evidence", "action"],
        "properties": {
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "target": { "type": "string" },
          "issue": { "type": "string" },
          "evidence": { "type": "string" },
          "action": { "type": "string" }
        }
      }
    }
  }
}
