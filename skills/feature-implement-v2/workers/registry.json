      "result_schema": "schemas/result/self-checker-result.schema.json",
      "enabled": true,
      "category": "execution",
      "supports_parallelism": false,
      "execution_mode": "workspace_write"
    },
    "cli-checker": {
      "file": "workers/cli-checker.md",
      "model": "haiku",
      "max_turns": 10,
      "permission_mode": "bypassPermissions",
      "tools": ["Bash", "Read", "Write"],
      "task_schema": "schemas/task/cli-checker-task.schema.json",
      "result_schema": "schemas/result/cli-checker-result.schema.json",
