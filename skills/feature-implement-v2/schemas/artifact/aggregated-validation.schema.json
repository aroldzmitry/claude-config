{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aggregated-validation.schema.json",
  "type": "object",
  "required": ["version", "type", "feature", "iteration", "findings"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "type": { "type": "string", "const": "aggregated-validation" },
    "feature": { "type": "string" },
    "iteration": { "type": "integer", "minimum": 0 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "message", "source_validators", "source_issue_ids", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning"] },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "message": { "type": "string" },
          "source_validators": { "type": "array", "items": { "type": "string" } },
          "source_issue_ids": { "type": "array", "items": { "type": "string" } },
          "dedupe_reason": { "type": "string" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    }
  }
}
