{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "self-checker-task.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "feature", "spec_dir", "inputs", "context", "output_path"],
  "properties": {
    "worker": { "type": "string", "const": "self-checker" },
    "inputs": {
      "type": "object",
      "required": ["project_context"],
      "properties": {
        "project_context": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "required": ["changed_files", "cli"],
      "properties": {
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "cli": {
          "type": "object",
          "properties": {
            "lint": { "type": "string" },
            "typecheck": { "type": "string" }
          }
        }
      }
    }
  }
}
