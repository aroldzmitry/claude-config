{
  "version": 1,
  "runtime_family": "feature-implement-v2",
  "defaults": {
    "timeout_ms": 300000,
    "permission_mode": "default",
    "cwd_policy": "project-root"
  },
  "workers": {
    "preprocessor": {
      "file": "workers/preprocessor.md",
      "model": "haiku",
      "max_turns": 10,
      "permission_mode": "acceptEdits",
      "tools": ["Read", "Glob", "Write"],
      "task_schema": "schemas/task/preprocessor-task.schema.json",
      "result_schema": "schemas/result/preprocessor-result.schema.json",
      "enabled": true,
      "category": "preprocess",
      "supports_parallelism": false,
      "execution_mode": "workspace_write"
    },
    "planner": {
      "file": "workers/planner.md",
      "model": "opus",
      "max_turns": 20,
      "permission_mode": "acceptEdits",
      "tools": ["Read", "Glob", "Grep", "Write"],
      "task_schema": "schemas/task/planner-task.schema.json",
      "result_schema": "schemas/result/planner-result.schema.json",
      "enabled": true,
      "category": "planning",
      "supports_parallelism": false,
      "execution_mode": "workspace_write"
    },
    "plan-validator": {
      "file": "workers/plan-validator.md",
      "model": "sonnet",
      "max_turns": 15,
      "permission_mode": "acceptEdits",
      "tools": ["Read", "Glob", "Grep", "Edit", "Write"],
      "task_schema": "schemas/task/plan-validator-task.schema.json",
      "result_schema": "schemas/result/plan-validator-result.schema.json",
      "enabled": true,
      "category": "planning",
      "supports_parallelism": false,
      "execution_mode": "workspace_write"
    },
    "test-writer": {
      "file": "workers/test-writer.md",
      "model": "sonnet",
      "max_turns": 40,
      "permission_mode": "acceptEdits",
      "tools": ["Read", "Glob", "Grep", "Write"],
      "task_schema": "schemas/task/test-writer-task.schema.json",
      "result_schema": "schemas/result/test-writer-result.schema.json",
      "enabled": true,
      "category": "planning",
      "supports_parallelism": false,
      "execution_mode": "workspace_write"
    },
    "coder-implement": {
      "file": "workers/coder-implement.md",
      "model": "opus",
      "max_turns": 50,
      "permission_mode": "bypassPermissions",
      "tools": ["Read", "Glob", "Grep", "Write", "Edit", "Bash"],
      "task_schema": "schemas/task/coder-implement-task.schema.json",
      "result_schema": "schemas/result/coder-implement-result.schema.json",
      "enabled": true,
      "category": "execution",
      "supports_parallelism": false,
      "execution_mode": "workspace_write"
    },
    "self-checker": {
      "file": "workers/self-checker.md",
      "model": "sonnet",
      "max_turns": 20,
      "permission_mode": "bypassPermissions",
