{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "improvement-analyzer-task.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "feature", "spec_dir", "inputs", "context", "output_path"],
  "properties": {
    "worker": { "type": "string", "const": "improvement-analyzer" },
    "inputs": {
      "type": "object",
      "required": ["run_summary"],
      "properties": {
        "run_summary": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "const": "post-run-analysis" }
      }
    }
  }
}
