{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cli-checker-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "cli-checker" },
    "data": {
      "type": "object",
      "required": ["commands_run", "result", "relevant_findings_count"],
      "properties": {
        "commands_run": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "command", "status"],
            "properties": {
              "name": { "type": "string" },
              "command": { "type": "string" },
              "status": { "type": "string", "enum": ["passed", "failed", "skipped"] }
            }
          }
        },
        "result": { "type": "string", "enum": ["clean", "warnings_found", "failures_found", "skipped"] },
        "relevant_findings_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
