{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "normalized-input-index.schema.json",
  "type": "object",
  "required": ["version", "feature", "inputs"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "feature": { "type": "string" },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "source", "output"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["technical-requirements", "business-requirements", "ui-requirements", "test-cases"]
          },
          "source": { "type": "string" },
          "output": { "type": "string" }
        }
      }
    }
  }
}
