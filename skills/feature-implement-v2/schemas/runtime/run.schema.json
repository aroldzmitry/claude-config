{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "run.schema.json",
  "type": "object",
  "required": ["version", "run_id", "runtime_family", "workflow", "feature", "status", "progress", "iterations", "outcome", "cost", "signals", "artifacts"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "runtime_family": { "type": "string", "const": "feature-implement-v2" },
    "workflow": { "type": "string", "const": "feature-implement-v2" },
    "feature": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "completed_with_unresolved_issues", "failed", "stopped"]
    },
    "current_phase": { "type": ["string", "null"] },
    "current_worker": { "type": ["string", "null"] },
    "current_step_id": { "type": ["string", "null"] },
    "progress": {
      "type": "object",
      "required": ["total_steps", "completed_steps"],
      "properties": {
        "total_steps": { "type": ["integer", "null"], "minimum": 0 },
        "completed_steps": { "type": "integer", "minimum": 0 }
      }
    },
    "iterations": {
      "type": "object",
      "required": ["cli", "validation"],
      "properties": {
        "cli": { "type": "integer", "minimum": 0 },
        "validation": { "type": "integer", "minimum": 0 }
      }
    },
    "outcome": {
      "type": "object",
      "required": ["issues_remaining", "unresolved_workers"],
      "properties": {
        "issues_remaining": { "type": "integer", "minimum": 0 },
        "unresolved_workers": { "type": "integer", "minimum": 0 }
      }
    },
    "cost": {
      "type": "object",
      "required": ["duration_ms"],
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "signals": {
      "type": "object",
      "required": ["retry_count", "worker_failures", "compactions"],
      "properties": {
        "retry_count": { "type": "integer", "minimum": 0 },
        "worker_failures": { "type": "integer", "minimum": 0 },
        "compactions": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": { "type": "object" }
  }
}
