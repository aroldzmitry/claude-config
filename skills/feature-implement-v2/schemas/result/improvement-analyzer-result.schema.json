{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "improvement-analyzer-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "improvement-analyzer" },
    "data": {
      "type": "object",
      "required": ["result", "suggestion_count"],
      "properties": {
        "result": { "type": "string", "enum": ["no_suggestions", "suggestions_found"] },
        "suggestion_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
