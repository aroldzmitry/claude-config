{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Read(/Users/dmitry/WebstormProjects/**)",
      "Write(/Users/dmitry/WebstormProjects/**)",
      "Edit(/Users/dmitry/WebstormProjects/**)",
      "Read(**/.claude/**)",
      "Write(**/.claude/**)",
      "Edit(**/.claude/**)",
      "Bash(mkdir:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(yarn:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(cat /Users/dmitry/WebstormProjects/**)",
      "Bash(cat /Users/dmitry/farevio_app/**)",
      "Bash(chmod:*)",
      "Bash(bash -n:*)",
      "Bash",
      "Write",
      "Edit",
      "Read"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/.ssh/*)",
      "Read(**/.aws/*)",
      "Read(**/credentials.json)",
      "Read(**/serviceAccountKey.json)",
      "Bash(cat **/.env*)",
      "Bash(grep **/.env*)",
      "Bash(head **/.env*)",
      "Bash(tail **/.env*)",
      "Bash(sed **/.env*)",
      "Bash(awk **/.env*)",
      "Bash(cat **/*.pem)",
      "Bash(cat **/*.key)",
      "Bash(cat **/*.p12)",
      "Bash(cat **/.ssh/*)",
      "Bash(cat **/.aws/*)",
      "Bash(cat **/credentials.json)",
      "Bash(cat **/serviceAccountKey.json)"
    ],
    "ask": [],
    "defaultMode": "bypassPermissions"
  },
  "enabledMcpjsonServers": [
    "trello",
    "playwright"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-validator.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); model=$(echo \"$input\" | jq -r '.model.display_name // empty'); out=\"\"; [ -n \"$used\" ] && out=\"$(printf '%.0f' \"$used\")% used\"; [ -n \"$model\" ] && out=\"$out | $model\"; echo \"${out# | }\""
  },
  "autoUpdatesChannel": "stable",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "effortLevel": "medium"
}
