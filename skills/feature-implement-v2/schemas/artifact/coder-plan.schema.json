{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coder-plan.schema.json",
  "type": "object",
  "required": ["version", "type", "feature", "step_count", "steps"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "type": { "type": "string", "const": "coder-plan" },
    "feature": { "type": "string" },
    "step_count": { "type": "integer", "minimum": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["number", "title", "files", "action", "description"],
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "action": { "type": "string", "enum": ["create", "modify", "delete"] },
          "description": { "type": "string" },
          "spec_deviation": { "type": "boolean" },
          "completion_criteria": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
