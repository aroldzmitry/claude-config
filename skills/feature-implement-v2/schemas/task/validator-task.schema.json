{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "validator-task.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "feature", "spec_dir", "inputs", "context", "output_path"],
  "properties": {
    "inputs": {
      "type": "object",
      "properties": {
        "technical_requirements": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "iteration": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
