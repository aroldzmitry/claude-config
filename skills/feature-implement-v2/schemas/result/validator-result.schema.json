{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "validator-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "data": {
      "type": "object",
      "required": ["result", "issue_count"],
      "properties": {
        "result": { "type": "string", "enum": ["clean", "issues_found"] },
        "issue_count": { "type": "integer", "minimum": 0 }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "file", "line", "code", "message", "source"],
        "properties": {
          "severity": { "type": "string", "enum": ["error", "warning"] },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "source": { "type": "string" },
          "column": { "type": "integer" },
          "confidence": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    }
  }
}
