{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "false-positives.schema.json",
  "type": "object",
  "required": ["version", "type", "items"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "type": { "type": "string", "const": "false-positives" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "file", "code", "message"],
        "properties": {
          "source": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "suppression_reason": { "type": "string" }
        }
      }
    }
  }
}
