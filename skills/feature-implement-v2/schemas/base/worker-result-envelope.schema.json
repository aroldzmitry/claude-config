{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "worker-result-envelope.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "kind": { "type": "string", "const": "agent-result" },
    "workflow": { "type": "string", "const": "feature-implement-v2" },
    "run_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "worker": { "type": "string", "minLength": 1 },
    "execution_status": {
      "type": "string",
      "enum": ["succeeded", "failed", "blocked", "skipped", "invalid_result", "timeout"]
    },
    "next_action": {
      "type": "string",
      "enum": ["continue", "retry", "fix", "stop", "await-input"]
    },
    "summary": { "type": "string" },
    "data": { "type": "object" },
    "issues": { "type": "array" },
    "artifacts": { "type": "array" },
    "metrics": {
      "type": "object",
      "required": ["duration_ms"],
      "properties": {
        "duration_ms": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "signals": { "type": "object" }
      }
    }
  }
}
