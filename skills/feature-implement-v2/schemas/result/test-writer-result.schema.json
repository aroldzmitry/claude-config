{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "test-writer-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "test-writer" },
    "data": {
      "type": "object",
      "required": ["files_written"],
      "properties": {
        "files_written": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
