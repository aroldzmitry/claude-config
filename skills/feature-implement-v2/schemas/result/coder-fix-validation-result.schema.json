{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coder-fix-validation-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "coder-fix-validation" },
    "data": {
      "type": "object",
      "required": ["iteration", "files_changed", "fix_result", "remaining_issue_count"],
      "properties": {
        "iteration": { "type": "integer", "minimum": 0 },
        "files_changed": { "type": "array", "items": { "type": "string" } },
        "fix_result": { "type": "string", "enum": ["resolved", "partially_resolved", "unresolved", "no_change_needed"] },
        "remaining_issue_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
