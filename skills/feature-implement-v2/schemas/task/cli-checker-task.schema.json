{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cli-checker-task.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "feature", "spec_dir", "inputs", "context", "output_path"],
  "properties": {
    "worker": { "type": "string", "const": "cli-checker" },
    "inputs": { "type": "object" },
    "context": {
      "type": "object",
      "required": ["project_root"],
      "properties": {
        "project_root": { "type": "string" },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "iteration": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
