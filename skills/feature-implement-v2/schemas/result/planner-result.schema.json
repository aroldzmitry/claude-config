{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "planner-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "planner" },
    "data": {
      "type": "object",
      "required": ["step_count", "test_strategy", "spec_deviations"],
      "properties": {
        "step_count": { "type": "integer", "minimum": 0 },
        "test_strategy": {
          "type": "object",
          "required": ["skip", "reason"],
          "properties": {
            "skip": { "type": "boolean" },
            "reason": { "type": "string" }
          }
        },
        "spec_deviations": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
