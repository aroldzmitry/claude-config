    "validator-security": {
      "file": "workers/validator-security.md",
      "model": "sonnet",
      "max_turns": 30,
      "permission_mode": "plan",
      "tools": ["Read", "Glob", "Grep"],
      "task_schema": "schemas/task/validator-task.schema.json",
      "result_schema": "schemas/result/validator-result.schema.json",
      "enabled": true,
      "category": "validation",
      "supports_parallelism": true,
      "execution_mode": "read_only"
    },
    "validator-spec": {
      "file": "workers/validator-spec.md",
      "model": "sonnet",
      "max_turns": 30,
      "permission_mode": "plan",
      "tools": ["Read", "Glob", "Grep"],
      "task_schema": "schemas/task/validator-task.schema.json",
      "result_schema": "schemas/result/validator-result.schema.json",
      "enabled": true,
      "category": "validation",
      "supports_parallelism": true,
      "execution_mode": "read_only"
    },
    "aggregator": {
      "file": "workers/aggregator.md",
      "model": "sonnet",
      "max_turns": 60,
      "permission_mode": "acceptEdits",
      "tools": ["Read", "Glob", "Grep", "Write"],
      "task_schema": "schemas/task/aggregator-task.schema.json",
      "result_schema": "schemas/result/aggregator-result.schema.json",
      "enabled": true,
      "category": "validation",
      "supports_parallelism": false,
      "execution_mode": "workspace_write"
    },
    "coder-fix-validation": {
      "file": "workers/coder-fix-validation.md",
