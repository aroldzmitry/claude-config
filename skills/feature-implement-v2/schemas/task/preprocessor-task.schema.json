{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "preprocessor-task.schema.json",
  "allOf": [
    {
      "type": "object",
      "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "feature", "spec_dir", "inputs", "context", "output_path"],
      "properties": {
        "worker": { "type": "string", "const": "preprocessor" },
        "inputs": { "type": "object" },
        "context": { "type": "object" }
      }
    }
  ]
}
