{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Read(/Users/dmitry/WebstormProjects/**)",
      "Write(/Users/dmitry/WebstormProjects/**)",
      "Edit(/Users/dmitry/WebstormProjects/**)",
      "Read(**/.claude/**)",
      "Write(**/.claude/**)",
      "Edit(**/.claude/**)",
      "Bash(mkdir:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(yarn:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(cat /Users/dmitry/WebstormProjects/**)",
      "Bash(cat /Users/dmitry/farevio_app/**)",
      "Bash(python3 *figma_mcp.py*)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/.ssh/*)",
      "Read(**/.aws/*)",
      "Read(**/credentials.json)",
      "Read(**/serviceAccountKey.json)",
      "Bash(cat **/.env*)",
      "Bash(grep **/.env*)",
      "Bash(head **/.env*)",
      "Bash(tail **/.env*)",
      "Bash(sed **/.env*)",
      "Bash(awk **/.env*)",
      "Bash(cat **/*.pem)",
      "Bash(cat **/*.key)",
      "Bash(cat **/*.p12)",
      "Bash(cat **/.ssh/*)",
      "Bash(cat **/.aws/*)",
      "Bash(cat **/credentials.json)",
      "Bash(cat **/serviceAccountKey.json)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "claude-opus-4-6",
  "enabledMcpjsonServers": [
    "trello"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-validator.py"
          }
        ]
      }
    ]
  },
  "autoUpdatesChannel": "stable",
  "skipDangerousModePermissionPrompt": true
}
