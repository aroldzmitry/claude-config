{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "test-writer-task.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "feature", "spec_dir", "inputs", "context", "output_path"],
  "properties": {
    "worker": { "type": "string", "const": "test-writer" },
    "inputs": {
      "type": "object",
      "required": ["technical_requirements", "test_plan", "coder_plan"],
      "properties": {
        "technical_requirements": { "type": "string" },
        "business_requirements": { "type": "string" },
        "test_cases": { "type": "string" },
        "test_plan": { "type": "string" },
        "coder_plan": { "type": "string" }
      }
    },
    "context": { "type": "object" }
  }
}
