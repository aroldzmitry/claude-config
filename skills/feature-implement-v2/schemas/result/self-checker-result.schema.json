{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "self-checker-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "self-checker" },
    "data": {
      "type": "object",
      "required": ["result"],
      "properties": {
        "result": { "type": "string", "enum": ["clean", "fixed"] },
        "issues_fixed": { "type": "integer", "minimum": 0 },
        "files_changed": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
