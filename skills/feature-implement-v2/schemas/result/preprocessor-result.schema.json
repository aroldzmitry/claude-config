{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "preprocessor-result.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "execution_status", "next_action", "summary", "data", "issues", "artifacts"],
  "properties": {
    "worker": { "type": "string", "const": "preprocessor" },
    "data": {
      "type": "object",
      "required": ["converted_count", "skipped_count"],
      "properties": {
        "converted_count": { "type": "integer", "minimum": 0 },
        "skipped_count": { "type": "integer", "minimum": 0 },
        "conversion_report": { "type": "string" },
        "normalized_input_index": { "type": "string" }
      }
    }
  }
}
