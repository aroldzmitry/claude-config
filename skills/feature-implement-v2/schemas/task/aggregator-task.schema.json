{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aggregator-task.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "feature", "spec_dir", "inputs", "context", "output_path"],
  "properties": {
    "worker": { "type": "string", "const": "aggregator" },
    "inputs": {
      "type": "object",
      "required": ["validator_results"],
      "properties": {
        "validator_results": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "iteration": { "type": "integer", "minimum": 0 },
        "previous_false_positives": { "type": "string" }
      }
    }
  }
}
