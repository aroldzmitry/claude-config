{
  "permissions": {
    "allow": [
      "Read(/Users/dmitry/WebstormProjects/**)",
      "Write(/Users/dmitry/WebstormProjects/**)",
      "Edit(/Users/dmitry/WebstormProjects/**)",
      "Read(**/.claude/**)",
      "Write(**/.claude/**)",
      "Edit(**/.claude/**)",
      "Read(/Users/dmitry/.claude/**)",
      "Write(/Users/dmitry/.claude/**)",
      "Edit(/Users/dmitry/.claude/**)",
      "Bash(mkdir:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "Bash(yarn:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(cat:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(../.env)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-validator.py"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true
}
