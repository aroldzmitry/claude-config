{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "test-plan.schema.json",
  "type": "object",
  "required": ["version", "type", "feature", "test_strategy"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "type": { "type": "string", "const": "test-plan" },
    "feature": { "type": "string" },
    "test_strategy": {
      "type": "object",
      "required": ["skip", "reason"],
      "properties": {
        "skip": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["area", "files"],
        "properties": {
          "area": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "kinds": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
