{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "worker-task-envelope.schema.json",
  "type": "object",
  "required": ["version", "kind", "workflow", "run_id", "request_id", "worker", "feature", "spec_dir", "inputs", "context", "output_path"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "kind": { "type": "string", "const": "agent-request" },
    "workflow": { "type": "string", "const": "feature-implement-v2" },
    "run_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "worker": { "type": "string", "minLength": 1 },
    "feature": { "type": "string", "minLength": 1 },
    "spec_dir": { "type": "string", "minLength": 1 },
    "inputs": { "type": "object" },
    "context": { "type": "object" },
    "output_path": { "type": "string", "minLength": 1 }
  }
}
