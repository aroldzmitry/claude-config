{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "technical-requirements.schema.json",
  "type": "object",
  "required": ["version", "source", "feature", "requirements"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "source": { "type": "string" },
    "feature": { "type": "string" },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "section": { "type": "string" },
          "text": { "type": "string" },
          "priority": { "type": "string", "enum": ["must", "should", "could", "wont"] },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "category": { "type": "string" }
        }
      }
    },
    "raw_sections": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
